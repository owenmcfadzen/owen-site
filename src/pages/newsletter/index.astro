---
import Base from '../../layouts/Base.astro';

const issues = [
  { num: "006", title: "The constraint is the feature", date: "Apr 2026", preview: "On iA Writer, deliberate limitations, and why the best tools say no.", imageColor: "#2a2a3a" },
  { num: "005", title: "Fifteen trips to Japan", date: "Mar 2026", preview: "What changes when a place stops being a destination and starts being a practice.", imageColor: "#3a3028" },
  { num: "004", title: "Building in public, quietly", date: "Feb 2026", preview: "The difference between performing work and sharing work.", imageColor: "#28303a" },
  { num: "003", title: "Musashi's sword", date: "Jan 2026", preview: "Hidden tools inside a katana's scabbard.", imageColor: "#2e2e28" },
  { num: "002", title: "Systems, not sequences", date: "Dec 2025", preview: "How architecture school taught me to think in maps.", imageColor: "#1e2e38" },
  { num: "001", title: "Hello, and the onigiri principle", date: "Nov 2025", preview: "Why default quality matters more than peak quality.", imageColor: "#2a2828" },
];
---
<Base title="Newsletter — Owen McFadzen" currentPage="newsletter">
  <div class="newsletter-page">

    <!-- Skeuomorphic envelope — above title -->
    <div class="envelope-wrap">
      <div class="envelope" role="img" aria-label="An open envelope">
        <!-- Back panel -->
        <div class="env-back"></div>
        <!-- Letter inside -->
        <div class="env-letter">
          <div class="env-letter-line"></div>
          <div class="env-letter-line env-letter-line--short"></div>
          <div class="env-letter-line"></div>
          <div class="env-letter-line env-letter-line--med"></div>
          <div class="env-letter-line env-letter-line--short"></div>
        </div>
        <!-- Front pocket (V-shape) -->
        <div class="env-pocket"></div>
        <!-- Flap (opens on hover) -->
        <div class="env-flap-wrap">
          <div class="env-flap"></div>
        </div>
      </div>
    </div>

    <h1 class="nl-title">Newsletter</h1>
    <p class="nl-desc">Shorter thinking, half-formed ideas, things I've found. Three parts: something on my mind, something I found, what's new on the site.</p>

    <div class="nl-subscribe">
      <div class="nl-subscribe-label">Subscribe</div>
      <form class="nl-form">
        <input type="email" placeholder="you@example.com" class="nl-input" />
        <button type="submit" class="nl-button">Subscribe</button>
      </form>
      <div class="nl-subscribe-note">Roughly monthly. No tracking. Also on RSS.</div>
    </div>

    <div class="nl-archive-label section-label--small">Archive — {issues.length} issues</div>

    {issues.map(issue => (
      <a href={`/newsletter/${issue.num}/`} class="nl-issue">
        {issue.imageColor && (
          <div class="nl-issue-image" style={`background: ${issue.imageColor};`}></div>
        )}
        <div class="nl-issue-body">
          <div class="nl-issue-meta">
            <span class="nl-issue-num">{issue.num}</span>
            <span class="nl-issue-date">{issue.date}</span>
          </div>
          <div class="nl-issue-title">{issue.title}</div>
          <div class="nl-issue-preview">{issue.preview}</div>
        </div>
      </a>
    ))}
  </div>
</Base>

<style>
  .newsletter-page {
    max-width: var(--col-width);
    margin: 0 auto;
    padding: clamp(60px, 10vw, 112px) var(--page-pad);
  }
  .nl-title {
    font-family: var(--font-sans);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 600;
    line-height: 1.15;
    margin: 0 0 20px;
    letter-spacing: -0.01em;
  }
  .nl-desc {
    font-family: var(--font-serif);
    font-size: var(--type-body);
    line-height: var(--lh-body);
    color: var(--color-body);
    margin: 0 0 var(--gap-element);
  }

  /* --- Skeuomorphic envelope: border-trick construction + 3D flap --- */
  .envelope-wrap {
    display: flex;
    justify-content: center;
    margin: 0 0 calc(var(--gap-section) + 4px);
  }
  .envelope {
    --env-w: clamp(240px, 36vw, 340px);
    --env-h: calc(var(--env-w) * 0.62);
    --env-color: #f0ede8;
    --env-color-dark: #e8e4dd;
    --env-pocket: #e2ded6;
    --env-flap: #ece8e0;
    --env-paper: #fcfbf9;
    position: relative;
    width: var(--env-w);
    height: var(--env-h);
    transform: rotate(-1.2deg);
    perspective: 600px;
    cursor: default;
  }
  [data-theme="dark"] .envelope {
    --env-color: #2e2c28;
    --env-color-dark: #282624;
    --env-pocket: #242220;
    --env-flap: #33302b;
    --env-paper: #3a3836;
  }

  /* Back panel */
  .env-back {
    position: absolute;
    inset: 0;
    background: var(--env-color);
    border-radius: 2px 2px 5px 5px;
    box-shadow:
      0 0.5px 1px rgba(0,0,0,0.1),
      0 2px 6px rgba(0,0,0,0.06),
      0 8px 24px rgba(0,0,0,0.05),
      0 16px 48px rgba(0,0,0,0.03);
  }
  [data-theme="dark"] .env-back {
    box-shadow:
      0 0.5px 1px rgba(0,0,0,0.3),
      0 2px 6px rgba(0,0,0,0.2),
      0 8px 24px rgba(0,0,0,0.15),
      0 16px 48px rgba(0,0,0,0.08);
  }

  /* Letter peeking out the top */
  .env-letter {
    position: absolute;
    left: 10%;
    right: 10%;
    bottom: 20%;
    top: -20%;
    background: var(--env-paper);
    border-radius: 2px;
    padding: 14% 12% 20%;
    box-shadow: 0 -1px 4px rgba(0,0,0,0.04);
    transition: top 0.4s cubic-bezier(0.2, 0, 0, 1);
    z-index: 1;
  }
  .envelope:hover .env-letter {
    top: -35%;
  }
  .env-letter-line {
    height: 2px;
    background: var(--color-border);
    border-radius: 1px;
    margin-bottom: 7px;
  }
  .env-letter-line--short { width: 50%; }
  .env-letter-line--med { width: 70%; }

  /* Front pocket — V-shape via borders */
  .env-pocket {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 0;
    border-left: calc(var(--env-w) / 2) solid var(--env-color-dark);
    border-right: calc(var(--env-w) / 2) solid var(--env-color-dark);
    border-top: calc(var(--env-h) * 0.55) solid transparent;
    border-bottom: 0;
    border-bottom-left-radius: 5px;
    border-bottom-right-radius: 5px;
    z-index: 2;
  }

  /* Flap — 3D fold with perspective */
  .env-flap-wrap {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 0;
    perspective: 400px;
  }
  .env-flap {
    width: 0;
    height: 0;
    border-left: calc(var(--env-w) / 2) solid transparent;
    border-right: calc(var(--env-w) / 2) solid transparent;
    border-top: calc(var(--env-h) * 0.52) solid var(--env-flap);
    transform-origin: top center;
    transform: rotateX(170deg);
    transition: transform 0.5s cubic-bezier(0.2, 0, 0, 1);
  }
  .envelope:hover .env-flap {
    transform: rotateX(155deg);
  }

  .nl-subscribe {
    background: var(--color-subtle);
    border-radius: 6px;
    padding: 24px 24px 20px;
    margin-bottom: calc(var(--gap-section) + 20px);
  }
  .nl-subscribe-label {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-fg);
    margin-bottom: 10px;
  }
  .nl-form {
    display: flex;
    gap: 8px;
  }
  .nl-input {
    flex: 1;
    font-family: var(--font-sans);
    font-size: var(--type-small);
    padding: 9px 12px;
    background: var(--color-bg);
    border: 0.5px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-fg);
    outline: none;
  }
  .nl-button {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    padding: 9px 16px;
    background: var(--color-fg);
    color: var(--color-bg);
    border: none;
    border-radius: 4px;
    cursor: pointer;
  }
  .nl-subscribe-note {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-faint);
    margin-top: 8px;
  }
  .nl-archive-label {
    margin-bottom: 12px;
  }

  /* --- Issue cards: image first, vertical layout, presence --- */
  .nl-issue {
    display: block;
    padding: var(--gap-element) 0 calc(var(--gap-section) - 4px);
    border-top: 0.5px solid var(--color-border);
    text-decoration: none;
    color: inherit;
  }
  .nl-issue:last-of-type {
    border-bottom: 0.5px solid var(--color-border);
  }
  .nl-issue:hover { text-decoration: none; }
  .nl-issue-image {
    aspect-ratio: 21/9;
    border-radius: 3px;
    width: 100%;
    margin-bottom: 20px;
  }
  .nl-issue-body {}
  .nl-issue-meta {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-bottom: 10px;
  }
  .nl-issue-num {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--color-faint);
  }
  .nl-issue-date {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .nl-issue-title {
    font-family: var(--font-sans);
    font-size: clamp(19px, 2.5vw, 24px);
    font-weight: 600;
    line-height: 1.25;
    margin-bottom: 8px;
    color: var(--color-fg);
    letter-spacing: -0.01em;
  }
  .nl-issue-preview {
    font-family: var(--font-sans);
    font-size: var(--type-small);
    line-height: var(--lh-small);
    color: var(--color-muted);
    max-width: 480px;
  }
</style>
