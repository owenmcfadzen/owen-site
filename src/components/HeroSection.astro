---
interface Props {
  category: string;
  title: string;
  subtitle: string;
  href: string;
  bg: string;
  fg: string;
  imageColor?: string;
}
const { category, title, subtitle, href, bg, fg, imageColor } = Astro.props;
const heroBg = imageColor || bg;
---
<section class="hero" style={`color:${fg};`}>
  <div class="hero-image" style={`background:${heroBg};`}></div>
  <div class="hero-gradient" style={`background: linear-gradient(to top, ${bg} 0%, ${bg}dd 35%, ${bg}66 60%, transparent 80%);`}></div>
  <div class="hero-content">
    <h5 class="hero-category">{category}</h5>
    <h2 class="hero-title">{title}</h2>
    <p class="hero-subtitle">{subtitle}</p>
    <div class="hero-cta">
      <a href={href} class="hero-button" style={`background:${fg}; color:${bg};`}>Read Article</a>
    </div>
  </div>
</section>

<style>
  .hero {
    height: var(--hero-height);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  .hero-image {
    position: absolute;
    inset: 0;
    z-index: 0;
    /* When real images: background-size: cover; background-position: center; */
  }
  .hero-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    padding: 0 var(--page-pad) clamp(28px, 5vw, 48px);
  }
  .hero-category {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.5;
    margin: 0 0 16px;
  }
  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(32px, 5.5vw, 56px);
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 12px;
    letter-spacing: -0.015em;
  }
  .hero-subtitle {
    font-family: var(--font-sans);
    font-size: clamp(15px, 1.6vw, 18px);
    font-weight: 400;
    line-height: 1.45;
    margin: 0;
    opacity: 0.6;
    max-width: 440px;
  }
  .hero-cta {
    margin-top: var(--gap-paragraph);
  }
  .hero-button {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: none;
    border-radius: 30px;
    padding: 0.7em 1.8em 0.6em;
    text-decoration: none;
    display: inline-block;
    transition: transform 0.1s;
  }
  .hero-button:hover {
    text-decoration: none;
    transform: scale(0.97);
  }
</style>
