---
<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-id">
        <div class="footer-name">Owen McFadzen</div>
        <div class="footer-location">Copenhagen, Denmark</div>
      </div>
      <div class="footer-links">
        <a href="https://linkedin.com/in/owenmcfadzen" class="footer-link">LinkedIn</a>
        <a href="/feed.xml" class="footer-feed">/feed</a>
      </div>
    </div>
    <hr class="divider" />
    <div class="footer-bottom">
      <span class="footer-motto">Plain surface, deep structure</span>
      <span class="footer-colophon">Charter · Inter · Astro</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg);
    padding: 0 var(--page-pad);
    transition: background 0.3s;
  }
  .footer-inner {
    border-top: 0.5px solid var(--color-border);
    padding: var(--gap-section) 0 var(--gap-element);
  }
  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--gap-section);
  }
  .footer-name {
    font-family: var(--font-serif);
    font-size: 15px;
    color: var(--color-muted);
  }
  .footer-location {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-faint);
    margin-top: 4px;
  }
  .footer-links {
    display: flex;
    gap: 20px;
    align-items: baseline;
  }
  .footer-link {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-link);
  }
  .footer-feed {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-link);
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-top: 20px;
  }
  .footer-motto {
    font-family: var(--font-serif);
    font-size: 12px;
    font-style: italic;
    color: var(--color-faint);
  }
  .footer-colophon {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-faint);
  }
</style>
