---
import Base from './Base.astro';

interface Props {
  title: string;
  subtitle: string;
  category: string;
  date: string;
  readTime: string;
  bg: string;
  fg: string;
  heroImageColor?: string;
  heroImageCaption?: string;
}

const { title, subtitle, category, date, readTime, bg, fg, heroImageColor, heroImageCaption } = Astro.props;
---
<Base title={`${title} — Owen McFadzen`} currentPage="home">
  <article>
    <!-- Hero: full-bleed image with gradient overlay -->
    <div class="article-hero" style={`color:${fg};`}>
      <div class="article-hero-image" style={`background:${heroImageColor || bg};`}></div>
      <div class="article-hero-gradient" style={`background: linear-gradient(to top, ${bg} 0%, ${bg}ee 25%, ${bg}88 50%, transparent 75%);`}></div>
      <div class="article-hero-content">
        <a href="/" class="back-link" style={`color:${fg};`}>← Back</a>
        <h5 class="section-label--small" style={`opacity:0.45;`}>{category}</h5>
        <h1 class="article-title">{title}</h1>
        <p class="article-subtitle">{subtitle}</p>
        <div class="article-meta">
          <span>{date}</span>
          <span class="meta-dot" style={`background:${fg};`}></span>
          <span>{readTime}</span>
        </div>
      </div>
    </div>

    <!-- Hero caption -->
    {heroImageCaption && (
      <div class="article-hero-caption">
        <figcaption>{heroImageCaption}</figcaption>
      </div>
    )}

    <!-- Body -->
    <div class="prose article-body">
      <slot />
    </div>
  </article>
</Base>

<style>
  .article-hero {
    position: relative;
    min-height: max(50vh, 420px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
  }
  .article-hero-image {
    position: absolute;
    inset: 0;
    z-index: 0;
    /* When real images: background-size: cover; background-position: center; */
  }
  .article-hero-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .article-hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--col-width);
    margin: 0 auto;
    padding: 0 var(--page-pad) clamp(36px, 5vw, 56px);
  }
  .back-link {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.45;
    text-decoration: none;
    margin-bottom: 40px;
  }
  .back-link:hover { opacity: 0.7; text-decoration: none; }
  .article-title {
    font-family: var(--font-serif);
    font-size: clamp(36px, 6vw, 60px);
    font-weight: 700;
    line-height: 1.08;
    margin: 0 0 14px;
    letter-spacing: -0.015em;
  }
  .article-subtitle {
    font-family: var(--font-sans);
    font-size: clamp(16px, 1.8vw, 19px);
    line-height: 1.45;
    margin: 0 0 24px;
    opacity: 0.6;
    max-width: 500px;
  }
  .article-meta {
    display: flex;
    gap: 14px;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.45;
  }
  .meta-dot {
    width: 2px;
    height: 2px;
    border-radius: 50%;
    opacity: 0.2;
  }
  .article-hero-caption {
    max-width: var(--col-width);
    margin: 0 auto;
    padding: 0 var(--page-pad);
  }
  .article-hero-caption figcaption {
    padding-top: 12px;
    padding-bottom: 0;
    margin-top: 0;
    border-top: none;
  }
  .article-body {
    padding-top: calc(var(--gap-section) + 8px);
    padding-bottom: var(--gap-section);
  }

  /* Prose typography for article body */
  .article-body :global(p) {
    font-family: var(--font-serif);
    font-size: var(--type-body);
    line-height: var(--lh-body);
    color: var(--color-body);
    margin: 0 0 var(--gap-paragraph);
  }
  .article-body :global(p.lede) {
    font-size: var(--type-lede);
    line-height: var(--lh-lede);
    color: var(--color-fg);
  }
  .article-body :global(h2) {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: var(--gap-section) 0 var(--gap-paragraph);
  }
  .article-body :global(figure) {
    margin: var(--gap-element) 0;
  }
  .article-body :global(.footnotes) {
    margin-top: var(--gap-section);
    padding-top: var(--gap-paragraph);
    border-top: 0.5px solid var(--color-border);
  }
  .article-body :global(.footnote-item) {
    display: flex;
    gap: 10px;
    margin-bottom: 10px;
    align-items: baseline;
  }
  .article-body :global(.footnote-num) {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-link);
    flex-shrink: 0;
    min-width: 14px;
  }
  .article-body :global(.footnote-text) {
    font-family: var(--font-sans);
    font-size: var(--type-small);
    line-height: var(--lh-small);
    color: var(--color-muted);
  }
</style>
