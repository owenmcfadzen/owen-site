---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const { title, description = 'Owen McFadzen — systems, craft, Japan, and the things worth paying attention to.', currentPage = 'home' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="alternate" type="application/rss+xml" title="Owen McFadzen" href="/feed.xml" />
</head>
<body>
  <Header currentPage={currentPage} />
  <main style="padding-top: var(--header-height);">
    <slot />
  </main>
  <Footer />
</body>
</html>
